{
  "name": "codega-ai-desktop",
  "productName": "CODEGA AI",
  "version": "2.3.31",
  "description": "CODEGA AI clean Windows-first desktop app.",
  "author": "CODEGA",
  "private": true,
  "main": "src/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "check": "node scripts/check.mjs",
    "test:reasoning": "node scripts/test-reasoning-guard.mjs",
    "test:verification": "node scripts/test-verification-hard-gate.mjs",
    "test:reasoning:regression": "node scripts/run-reasoning-regression.mjs",
    "test:model-updates": "node scripts/test-model-updates.mjs",
    "test:model-storage": "node scripts/test-model-storage.mjs",
    "test:chat-watchdog": "node scripts/test-chat-watchdog.mjs",
    "test:autonomous-development": "node scripts/test-autonomous-development.mjs",
    "test:agent-watch": "node scripts/test-agent-watch.mjs",
    "test:agent-loop": "node scripts/test-agent-loop-resilience.mjs",
    "test:runtime-policy": "node scripts/test-runtime-policy.mjs",
    "test:ci": "npm run check && npm run test:runtime-policy && npm run test:model-updates && npm run test:model-storage && npm run test:chat-watchdog && npm run test:autonomous-development && npm run test:agent-watch && npm run test:agent-loop && npm run test:reasoning && npm run test:verification && npm run test:reasoning:regression",
    "pack": "electron-builder --dir",
    "dist:win": "electron-builder --win nsis --x64 --publish never",
    "release:win": "electron-builder --win nsis --x64 --publish always",
    "dist:mac": "electron-builder --mac --publish never",
    "release:mac": "electron-builder --mac --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "tr.com.codega.codegaai",
    "artifactName": "CODEGA-AI-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "afterSign": "scripts/notarize-macos.cjs",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "dmg": {
      "title": "CODEGA AI ${version} ${arch}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CODEGA AI",
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "codegatr",
        "repo": "codegaai",
        "releaseType": "release"
      }
    ]
  }
}
