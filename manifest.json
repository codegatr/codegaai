{
  "name": "CODEGA AI",
  "slug": "codegaai",
  "version": "0.2.1",
  "phase": "Faz 2.1 - Kalıcı Sohbet (Claude tarzı sidebar)",
  "description": "Yerelde çalışan, kendi kendine öğrenen, çok modlu yapay zeka platformu. RTX 3060+ ve 16GB+ RAM için optimize edilmiştir.",
  "author": "CODEGA",
  "license": "MIT",
  "repo": "codegatr/codegaai",
  "homepage": "https://codega.com.tr",
  "release_url": "https://github.com/codegatr/codegaai/releases/latest",
  "released_at": "2026-05-08",
  "requires": {
    "python": ">=3.10,<3.13",
    "python_note": "3.13+ desteklenmiyor (pywebview pythonnet bağımlılığı henüz wheel yayınlamadı)",
    "os": ["windows", "linux", "macos"],
    "ram_gb_min": 16,
    "ram_gb_recommended": 24,
    "vram_gb_min": 6,
    "vram_gb_recommended": 12,
    "disk_gb_min": 60,
    "cuda": ">=11.8 (NVIDIA için)"
  },
  "features": {
    "desktop_window": true,
    "browser_fallback": true,
    "fastapi_backend": true,
    "system_check": true,
    "persistent_chats": true,
    "chat_history_sidebar": true,
    "chat_rename": true,
    "chat_delete": true,
    "auto_update": true,
    "installer": true,
    "chat": false,
    "code": false,
    "image_generation": false,
    "video_generation": false,
    "tts": false,
    "asr": false,
    "rag_memory": false,
    "self_learning": false
  },
  "models": {
    "llm": {
      "default": "qwen2.5-7b-instruct-q4_k_m",
      "alternatives": ["llama-3.1-8b-instruct-q4", "aya-expanse-8b-q4", "phi-3.5-mini-q4"]
    },
    "embedding": {"default": "bge-m3"},
    "image": {
      "default": "stable-diffusion-xl-base-1.0",
      "alternatives": ["flux.1-schnell", "sdxl-turbo"]
    },
    "video": {"default": "cogvideox-2b"},
    "tts": {"default": "xtts-v2", "alternatives": ["piper-tr"]},
    "asr": {"default": "faster-whisper-large-v3"}
  },
  "phases_complete": [
    "Faz 1 - Temel İskelet (yapılandırma, başlatıcı, kurulum, logger, sistem kontrol)",
    "Faz 2 - Masaüstü UI (PyWebView pencere, FastAPI backend, dark theme HTML/CSS/JS arayüz)",
    "Faz 2.1 - Kalıcı Sohbet (SQLite chat store, Claude tarzı sidebar, çoklu sohbet, başlık otomatik üretimi, yeniden adlandırma + silme, install.bat Python 3.10-3.12 detect)"
  ],
  "phases_pending": [
    "Faz 3 - LLM Motoru (Qwen 2.5 7B + BGE-M3 + ChromaDB RAG)",
    "Faz 4 - Görsel Üretim (SDXL / FLUX.1)",
    "Faz 5 - Ses (XTTS v2 + faster-whisper)",
    "Faz 6 - Video Üretim (CogVideoX-2B)",
    "Faz 7 - Self-Learning (DPO + LoRA hot-swap)",
    "Faz 8 - Tek .exe paket + Akıllı Güncelle"
  ]
}
